.plan-container {
  padding: 20px;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  margin-bottom: 30px;
  text-align: center;
}

.title {
  display: block;
  font-size: 24px;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8px;
}

.subtitle {
  display: block;
  font-size: 14px;
  color: #666666;
}

.generate-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  background-color: white;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  margin-bottom: 20px;
}

.generate-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #1976D2;
  color: white;
  border-radius: 8px;
  padding: 15px 30px;
  font-size: 16px;
  font-weight: 500;
  margin-bottom: 16px;
}

.generate-icon {
  font-size: 24px;
  margin-right: 12px;
}

.hint {
  font-size: 14px;
  color: #666666;
  text-align: center;
  line-height: 1.5;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60px 0;
  background-color: white;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  margin-bottom: 20px;
}

.plan-content {
  margin-bottom: 20px;
}

.assessment-card,
.weak-points-card,
.suggestions-card,
.encouragement-card {
  background-color: white;
  border-radius: 8px;
  padding: 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  margin-bottom: 16px;
}

.card-title {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12px;
}

.assessment-text {
  font-size: 14px;
  line-height: 1.5;
  color: #666666;
}

.weak-points-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tag {
  padding: 6px 12px;
  border-radius: 16px;
  font-size: 12px;
  font-weight: 500;
}

.tag-orange {
  background-color: #FFF3E0;
  color: #FF9800;
}

.suggestions-list {
  margin-top: 12px;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12px;
}

.suggestion-icon {
  font-size: 16px;
  margin-right: 12px;
  flex-shrink: 0;
  margin-top: 2px;
}

.suggestion-text {
  flex: 1;
  font-size: 14px;
  line-height: 1.5;
  color: #666666;
}

.encouragement-card {
  background-color: #E3F2FD;
  border-left: 4px solid #1976D2;
}

.encouragement-text {
  font-size: 16px;
  line-height: 1.5;
  color: #1976D2;
  font-weight: 500;
  text-align: center;
  padding: 12px;
  background-color: white;
  border-radius: 4px;
}

.regenerate-btn {
  width: 100%;
  padding: 12px;
  border: 1px solid #1976D2;
  border-radius: 8px;
  background-color: white;
  color: #1976D2;
  font-size: 14px;
  font-weight: 500;
  margin-top: 8px;
