.home-container {
  padding: 20px;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  margin-bottom: 30px;
}

.welcome {
  display: block;
  font-size: 24px;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8px;
}

.subtitle {
  display: block;
  font-size: 16px;
  color: #666666;
}

.section {
  margin-bottom: 30px;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 18px;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16px;
}

.count {
  font-size: 14px;
  color: #666666;
  font-weight: normal;
}

.assignment-cards {
  margin-bottom: 20px;
}

.assignment-card {
  background-color: white;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.assignment-card.pending {
  border-left: 4px solid #1976D2;
}

.assignment-card.completed {
  border-left: 4px solid #4CAF50;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.assignment-title {
  font-size: 16px;
  font-weight: 600;
  color: #333333;
  flex: 1;
}

.assignment-subject {
  font-size: 12px;
  padding: 4px 12px;
  background-color: #E3F2FD;
  color: #1976D2;
  border-radius: 12px;
}

.card-body {
  margin-bottom: 12px;
}

.assignment-info {
  display: block;
  font-size: 14px;
  color: #666666;
  margin-bottom: 4px;
}

.assignment-date {
  display: block;
  font-size: 12px;
  color: #999999;
}

.assignment-score {
  display: block;
  font-size: 14px;
  color: #4CAF50;
  font-weight: 500;
}

.card-footer {
  text-align: right;
}

.start-btn {
  background-color: #1976D2;
  color: white;
  border-radius: 4px;
  padding: 6px 12px;
  font-size: 14px;
  font-weight: 500;
}

.view-btn {
  font-size: 14px;
  color: #1976D2;
  font-weight: 500;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 0;
  color: #999999;
  font-size: 14px;
  background-color: white;
  border-radius: 8px;
  margin-bottom: 20px;
}