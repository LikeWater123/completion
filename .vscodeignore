# 忽略敏感文件
*.key
*.pem
*.crt
*.env
*.secret
config.json
credentials.json
serviceAccountKey.json

# 忽略开发文件
.vscode/
.git/
.gitignore
.vscodeignore
*.code-workspace

# 忽略构建/编译文件
out/
dist/
*.vsix
*.log
npm-debug.log*

# 忽略node_modules（默认会忽略，但明确写出更好）
node_modules/

# 忽略TypeScript源文件（如果已编译）
src/**/*.ts
!src/**/*.d.ts
